{
  "expo": {
    "name": "Rosty",
    "slug": "rosty",
    "version": "0.1.0",
    "scheme": "rosty",
    "orientation": "portrait",
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rosty.mobile"
    },
    "android": {
      "package": "com.rosty.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    }
  }
}
