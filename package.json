{
  "name": "rosty",
  "private": true,
  "version": "0.1.0",
  "description": "Wedding hall staff scheduling mobile app.",
  "packageManager": "pnpm@10.32.1",
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "node scripts/install-supabase-cli.cjs",
    "start": "node scripts/run-expo.cjs start",
    "android": "node scripts/run-expo.cjs start --android",
    "ios": "node scripts/run-expo.cjs start --ios",
    "web": "node scripts/run-expo.cjs start --web",
    "lint": "eslint src tests e2e scripts eslint.config.js jest.config.cjs .detoxrc.js --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "build": "node scripts/build-export.cjs",
    "native:prebuild": "node scripts/run-expo.cjs prebuild",
    "prebuild:android": "node scripts/run-expo.cjs prebuild --platform android",
    "prebuild:ios": "node scripts/run-expo.cjs prebuild --platform ios",
    "test:e2e:android": "node scripts/run-e2e.cjs android",
    "test:e2e:android:run": "node scripts/run-e2e.cjs android",
    "test:e2e:android:build": "node scripts/run-e2e.cjs android --build",
    "test:e2e:ios": "node scripts/run-e2e.cjs ios",
    "test:e2e:ios:run": "node scripts/run-e2e.cjs ios",
    "test:e2e:ios:build": "node scripts/run-e2e.cjs ios --build",
    "supabase:install": "node scripts/install-supabase-cli.cjs --required",
    "supabase": "node scripts/run-supabase.cjs",
    "supabase:migrations:link": "node scripts/run-supabase-migrations.cjs link",
    "supabase:migrations:status": "node scripts/run-supabase-migrations.cjs status",
    "supabase:migrations:dry-run": "node scripts/run-supabase-migrations.cjs dry-run",
    "supabase:migrations:apply": "node scripts/run-supabase-migrations.cjs apply",
    "supabase:first-admin": "node scripts/run-supabase-first-admin.cjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.54.0",
    "@tanstack/react-query": "^5.90.21",
    "expo": "~54.0.33",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.66.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "detox": "^20.47.0",
    "eslint": "^9.38.0",
    "eslint-config-expo": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "prettier": "^3.6.2",
    "react-test-renderer": "19.1.0",
    "supabase": "^2.81.3",
    "typescript": "^5.9.3"
  }
}
