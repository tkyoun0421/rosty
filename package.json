{
  "name": "rosty",
  "private": true,
  "version": "0.1.0",
  "description": "Wedding hall staff scheduling mobile app.",
  "packageManager": "pnpm@10.32.1",
  "main": "expo-router/entry",
  "scripts": {
    "start": "node scripts/run-expo.cjs start",
    "android": "node scripts/run-expo.cjs start --android",
    "ios": "node scripts/run-expo.cjs start --ios",
    "web": "node scripts/run-expo.cjs start --web",
    "lint": "eslint app src tests e2e scripts eslint.config.js jest.config.cjs .detoxrc.js --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "build": "node scripts/build-export.cjs",
    "native:prebuild": "node scripts/run-expo.cjs prebuild",
    "prebuild:android": "node scripts/run-expo.cjs prebuild --platform android",
    "prebuild:ios": "node scripts/run-expo.cjs prebuild --platform ios",
    "test:e2e:android": "node scripts/run-e2e.cjs android",
    "test:e2e:android:run": "node scripts/run-e2e.cjs android",
    "test:e2e:android:build": "node scripts/run-e2e.cjs android --build",
    "test:e2e:ios": "node scripts/run-e2e.cjs ios",
    "test:e2e:ios:run": "node scripts/run-e2e.cjs ios",
    "test:e2e:ios:build": "node scripts/run-e2e.cjs ios --build"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.6",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@supabase/supabase-js": "^2.54.0",
    "@tanstack/react-query": "^5.90.21",
    "expo": "^55.0.6",
    "expo-constants": "^55.0.7",
    "expo-linking": "^55.0.7",
    "expo-router": "^5.1.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.66.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "^4.1.3",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-screens": "^4.16.0",
    "react-native-web": "^0.21.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.13",
    "babel-preset-expo": "^55.0.7",
    "detox": "^20.47.0",
    "eslint": "^9.38.0",
    "eslint-config-expo": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "prettier": "^3.6.2",
    "react-test-renderer": "19.2.0",
    "typescript": "^5.9.3"
  }
}
