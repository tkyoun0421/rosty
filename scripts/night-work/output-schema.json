{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["CONTINUE", "BLOCKED"]
    },
    "reason": {
      "type": "string",
      "enum": [
        "slice_complete",
        "approval_required",
        "destructive_change",
        "requirement_conflict",
        "external_blocker",
        "scope_exhausted"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "validation": {
      "type": "string",
      "minLength": 1
    },
    "next_step": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["status", "reason", "summary", "validation", "next_step"]
}
