EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_KAKAO_NATIVE_APP_KEY=
EXPO_PUBLIC_NAVER_CLIENT_ID=

# Optional for CLI rollout. Prefer storing rollout-only secrets in `.env.local`
# or CI secret storage. The migration scripts reject these example placeholders
# and allow `.env.local` or process-level secrets to override them cleanly.
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_ACCESS_TOKEN=your-personal-access-token
SUPABASE_DB_PASSWORD=your-db-password
